# syntax=docker/dockerfile:1.4

#
# Build stage: Compile 3D Slicer from source + modules
#
FROM ubuntu:22.04 AS slicer-builder

# Prevent interactive prompts during apt installs (e.g. timezone, geographic area)
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install build dependencies
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        subversion \
        build-essential \
        cmake \
        cmake-curses-gui \
        cmake-qt-gui \
        qtmultimedia5-dev \
        qttools5-dev \
        libqt5xmlpatterns5-dev \ 
        libqt5svg5-dev \
        libqt5opengl5-dev \
        qtwebengine5-dev \ 
        qtscript5-dev \
        qtbase5-private-dev \
        libqt5x11extras5-dev \
        libxt-dev \
        libssl-dev \
        ca-certificates \
        ccache

# Add ROS 2 Humble apt repository
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        gnupg \
        lsb-release \
    && curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
       -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
       http://packages.ros.org/ros2/ubuntu $(lsb_release -cs) main" \
       > /etc/apt/sources.list.d/ros2.list

# Install ROS Humble desktop + build tools needed for SlicerROS2
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
        ros-humble-desktop \
        ros-humble-rosbag2 \
        ros-humble-rosbag2-storage \
        ros-humble-rosbag2-transport \
        ros-humble-joint-state-publisher \
        ros-humble-joint-state-publisher-gui \
        ros-humble-xacro \
        ros-humble-moveit-msgs \
        ros-humble-object-recognition-msgs \
        ros-humble-cv-bridge \
        ros-humble-vision-opencv \
        ros-humble-image-transport \
        python3-colcon-common-extensions \
        python3-vcstool \
        python3-pykdl \
        python3-rosdep \
        libxml2-dev \
        libraw1394-dev \
        libncurses5-dev \
        libcppunit-dev \
        libbluetooth-dev

# Set up ccache for faster rebuilds
ENV CCACHE_DIR=/cache/ccache
ENV PATH="/usr/lib/ccache:${PATH}"

# Clone Slicer source with shallow clone for faster download
WORKDIR /root/slicer
RUN --mount=type=cache,target=/root/.git \
    git clone --depth 1 --branch v5.8.1 https://github.com/slicer/Slicer

# Configure CMake
RUN mkdir -p Slicer-SuperBuild-Release && \
    cd Slicer-SuperBuild-Release && \
    cmake \
        -DCMAKE_BUILD_TYPE:STRING=Release \
        -DSlicer_USE_SYSTEM_OpenSSL=ON \
        -DCMAKE_C_COMPILER_LAUNCHER=ccache \
        -DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
        ../Slicer

# Build with all available cores using cache mount for ccache
WORKDIR /root/slicer/Slicer-SuperBuild-Release
RUN --mount=type=cache,target=/cache/ccache \
    make -j$(nproc)

# Package Slicer
RUN cd Slicer-build && \
    make package && \
    mkdir -p /root/slicer/packages && \
    mv *.tar.gz /root/slicer/packages/

#
# Build Slicer modules
#
WORKDIR /root/slicer

# Create modules directory
RUN mkdir -p /root/slicer/modules
RUN mkdir -p /root/slicer/packages

#
# SlicerOpenIGTLink
#
RUN mkdir -p /root/slicer/modules \
    && cd /root/slicer/modules \
    && git clone https://github.com/openigtlink/SlicerOpenIGTLink \
    && mkdir SlicerOpenIGTLink-build \
    && cd SlicerOpenIGTLink-build \
    && cmake -DCMAKE_BUILD_TYPE:STRING=Release -DSlicer_DIR:PATH=/root/slicer/Slicer-SuperBuild-Release/Slicer-build ../SlicerOpenIGTLink \
    && make -j4 \
    && cd inner-build \
    && make package \
    && mv *.tar.gz /root/slicer/packages

#
# SlicerIGSIO
#
RUN mkdir -p /root/slicer/modules \
    && cd /root/slicer/modules \
    && git clone https://github.com/IGSIO/SlicerIGSIO\
    && mkdir SlicerIGSIO-build \
    && cd SlicerIGSIO-build \
    && cmake -DCMAKE_BUILD_TYPE:STRING=Release -DSlicer_DIR:PATH=/root/slicer/Slicer-SuperBuild-Release/Slicer-build ../SlicerIGSIO \
    && make -j4 \
    && cd inner-build \
    && make package \
    && mkdir -p /root/slicer/packages \
    && mv *.tar.gz /root/slicer/packages


#
# SlicerIGT
#
RUN mkdir -p /root/slicer/modules \
    && cd /root/slicer/modules \
    && git clone https://github.com/SlicerIGT/SlicerIGT\
    && mkdir SlicerIGT-build \
    && cd SlicerIGT-build \
    && cmake -DCMAKE_BUILD_TYPE:STRING=Release -DSlicer_DIR:PATH=/root/slicer/Slicer-SuperBuild-Release/Slicer-build -DSlicerIGSIO_DIR:PATH=/root/slicer/modules/SlicerIGSIO-build/inner-build ../SlicerIGT \
    && make -j4 \
    && make package \ 
    && mkdir -p /root/slicer/packages \
    && mv *.tar.gz /root/slicer/packages

#
# Parallel Processing
#
RUN mkdir -p /root/slicer/modules \
    && cd /root/slicer/modules \
    && git clone https://github.com/pieper/SlicerParallelProcessing \
    && mkdir SlicerParallelProcessing-build \
    && cd SlicerParallelProcessing-build \
    && cmake -DCMAKE_BUILD_TYPE:STRING=Release -DSlicer_DIR:PATH=/root/slicer/Slicer-SuperBuild-Release/Slicer-build ../SlicerParallelProcessing \
    && make -j4 \
    && make package \
    && mkdir -p /root/slicer/packages \
    && mv *.tar.gz /root/slicer/packages
#     mv *.tar.gz /root/slicer/packages/

#
# SlicerDMRI
#
RUN cd /root/slicer/modules && \
    git clone https://github.com/SlicerDMRI/SlicerDMRI

# Patch VTK_to_DICOMTract.cxx to replace CODE_DCM_* macros that were removed
# in newer versions of DCMTK with their explicit DSRBasicCodedEntry equivalents.
# DCMTK CID 7261 codes: 113211=Deterministic, 113212=Probabilistic,
#                        113213=Global, 113217=Bootstrap
RUN sed -i \
    -e 's/CODE_DCM_Deterministic/DSRBasicCodedEntry("113211", "DCM", "Deterministic")/g' \
    -e 's/CODE_DCM_Probabilistic/DSRBasicCodedEntry("113212", "DCM", "Probabilistic")/g' \
    -e 's/CODE_DCM_Global/DSRBasicCodedEntry("113213", "DCM", "Global")/g' \
    -e 's/CODE_DCM_Bootstrap/DSRBasicCodedEntry("113217", "DCM", "Bootstrap")/g' \
    /root/slicer/modules/SlicerDMRI/Modules/Loadable/TractIO/TractIOCLI/VTK_to_DICOMTract.cxx

RUN cd /root/slicer/modules && \
    mkdir SlicerDMRI-build && \
    cd SlicerDMRI-build && \
    cmake \
        -DCMAKE_BUILD_TYPE:STRING=Release \
        -DSlicer_DIR:PATH=/root/slicer/Slicer-SuperBuild-Release/Slicer-build \
        -DCMAKE_C_COMPILER_LAUNCHER=ccache \
        -DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
        ../SlicerDMRI

RUN --mount=type=cache,target=/cache/ccache \
    cd /root/slicer/modules/SlicerDMRI-build && \
    make -j$(nproc) && \
    cd inner-build && \
    make package && \
    mv *.tar.gz /root/slicer/packages/


#
# Build SlicerROS2 module - NOW ENABLED
#
WORKDIR /root

# Clone slicer_ros2_module plus source-only deps that have no ros-humble-* apt binary:
#   - object_recognition_msgs: wg-perception, ros2 branch
#   - ros2_cisst_msgs: jhu-cisst, needed by slicer_ros2_module on Humble
#   - ros2_kortex: provides kortex_description package with Gen3 7DOF mesh files (.dae)
#   - ros2_robotiq_gripper: provides robotiq_description package with 2F-85 mesh files (.dae)
# The last two are required so Slicer can resolve package://kortex_description/...
# and package://robotiq_description/... URIs in robot_description messages from rossim
RUN mkdir -p /root/ros2_ws/src \
    && cd /root/ros2_ws/src \
    && git clone -b devel https://github.com/rosmed/slicer_ros2_module \
    && git clone -b ros2 https://github.com/wg-perception/object_recognition_msgs \
    && git clone https://github.com/jhu-cisst/ros2_cisst_msgs \
    && git clone --depth 1 https://github.com/Kinovarobotics/ros2_kortex.git \
    && git clone --depth 1 https://github.com/PickNikRobotics/ros2_robotiq_gripper.git

# Fix for ROS 2 Humble: Remove rosbag2 service clients that don't exist in Humble
# (Play, Stop, SplitBagFile are not available in ros-humble-rosbag2-interfaces)
RUN cd /root/ros2_ws/src/slicer_ros2_module/MRML \
    && sed -i '/rosbag2_interfaces\/srv\/Play/d' CMakeLists.txt \
    && sed -i '/rosbag2_interfaces\/srv\/SplitBagfile/d' CMakeLists.txt \
    && sed -i '/rosbag2_interfaces\/srv\/Stop/d' CMakeLists.txt

# Run rosdep to install any remaining apt-resolvable dependencies.
# --skip-keys skips simulation/hardware packages pulled in by ros2_kortex that
# are not available in the standard ROS Humble apt repo and are not needed in
# the Slicer container (it only needs the description/mesh packages, not the
# full Gazebo/ros2-control/MoveIt simulation stack).
RUN /bin/bash -c 'source /opt/ros/humble/setup.sh \
    && rosdep init 2>/dev/null || true \
    && rosdep update \
    && cd /root/ros2_ws \
    && rosdep install --from-paths src --ignore-src -r -y --rosdistro humble \
        --skip-keys " \
            ros_gz_bridge \
            ros_gz_sim \
            ros_gz_interfaces \
            gz_ros2_control \
            ign_ros2_control \
            ros2_control \
            ros2_controllers \
            controller_interface \
            hardware_interface \
            joint_state_broadcaster \
            moveit_ros_visualization \
            moveit_ros_warehouse \
            moveit_setup_assistant \
            kortex_driver \
            kortex_bringup \
            kortex_moveit_config \
            robotiq_controllers \
            robotiq_driver \
        " || true'

# Build kortex_description and robotiq_description with colcon so their
# share/ directories (meshes, URDFs) are installed and resolvable via
# package:// URIs when Slicer receives robot_description from rossim.
# These are description-only packages so the build is fast.
RUN /bin/bash -c 'source /opt/ros/humble/setup.bash \
    && cd /root/ros2_ws \
    && colcon build \
        --packages-select kortex_description robotiq_description \
        --cmake-args -DCMAKE_BUILD_TYPE=Release \
    && echo "Description packages built successfully" \
    && echo "kortex_description .dae files: $(find install/kortex_description -name *.dae | wc -l)" \
    && echo "robotiq_description .dae files: $(find install/robotiq_description -name *.dae | wc -l)"'

# SlicerROS2 uses vtkSTLReader for ALL mesh files regardless of extension.
# .dae (COLLADA) files are XML starting with <?xml, but vtkSTLReader expects
# STL format starting with 'solid' — causing parse errors at runtime.
#
# IMPORTANT: Do NOT use assimp for this conversion — assimp auto-detects the
# COLLADA up-axis (Y_UP) and rotates geometry to Z_UP on export, which twists
# each mesh link individually and makes the robot look broken/exploded in Slicer.
#
# Fix: use trimesh, which converts geometry to binary STL without applying any
# axis transformation — preserving the exact orientation from the URDF.
# The .dae filename is kept so URDF package:// references continue to resolve.
RUN apt-get update && apt-get install -y --no-install-recommends python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && pip3 install --quiet trimesh numpy pycollada
COPY dockerfiles/optimized/convertmesh.py /root/convertmesh.py
RUN python3 /root/convertmesh.py
