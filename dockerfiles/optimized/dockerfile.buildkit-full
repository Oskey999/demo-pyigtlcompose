# Build the full workspace with colcon
RUN /bin/bash -c 'source /opt/ros/humble/setup.bash && \
    mkdir -p /root/ros2_ws/build/slicer_ros2_cmake && \
    cd /root/ros2_ws/build/slicer_ros2_cmake && \
    cmake \
        -DSlicer_DIR=/root/slicer/Slicer-SuperBuild-Release/Slicer-build \
        -DCMAKE_BUILD_TYPE=Release \
        /root/ros2_ws/src/slicer_ros2_module && \
    make -j$(nproc) && \
    echo "=== Saving ROS2 modules to fixed path ===" && \
    mkdir -p /root/slicer/ros2_loadable_modules && \
    cp -r lib/Slicer-5.8/qt-loadable-modules/. /root/slicer/ros2_loadable_modules/ && \
    ls /root/slicer/ros2_loadable_modules/'

#
# Final stage: Copy built Slicer + modules into the webtop image
#
# kasmweb/core-ubuntu-jammy is Ubuntu 22.04 (Jammy) with browser-accessible desktop
# Access via: https://host:6901  |  User: kasm_user  |  Password: set via VNC_PW env var
FROM kasmweb/core-ubuntu-jammy:1.18.0

# Kasm runs as non-root by default — switch to root for all install steps
USER root

# Prevent interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Add ROS 2 Humble apt repository
RUN apt-get update && apt-get install -y --no-install-recommends curl gnupg lsb-release \
    && curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
       -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
       http://packages.ros.org/ros2/ubuntu $(lsb_release -cs) main" \
       > /etc/apt/sources.list.d/ros2.list

RUN apt-get update && apt-get install -y \
    libglib2.0-0 \
    libgl1 \
    libglu1-mesa \
    libxrender1 \
    libxcursor1 \
    libxft2 \
    libxinerama1 \
    qtbase5-dev \
    qtmultimedia5-dev \
    libqt5core5a \
    libqt5gui5 \
    libqt5widgets5 \
    libqt5network5 \
    libqt5opengl5 \
    libqt5svg5 \
    libqt5x11extras5 \
    libqt5xml5 \
    libqt5xmlpatterns5 \
    libqt5multimedia5 \
    libqt5multimediawidgets5 \
    libqt5webkit5 \
    libqt5webengine5 \
    libqt5webenginewidgets5 \
    libnsl2 \
    ros-humble-desktop \
    ros-humble-rosbag2 \
    ros-humble-rosbag2-storage \
    ros-humble-rosbag2-transport \
    ros-humble-joint-state-publisher \
    ros-humble-joint-state-publisher-gui \
    ros-humble-xacro \
    ros-humble-moveit-msgs \
    ros-humble-object-recognition-msgs \
    python3-colcon-common-extensions \
    && rm -rf /var/lib/apt/lists/*

# Source ROS Humble automatically for all shell sessions
RUN echo 'source /opt/ros/humble/setup.bash' >> /etc/bash.bashrc && \
    echo 'source /opt/ros/humble/setup.bash' >> /etc/profile
    
# Copy all built packages from builder stage
COPY --from=slicer-builder /root/slicer/packages /root/slicer/packages

# Copy the built ROS2 workspace (includes SlicerROS2 module)
# COPY --from=slicer-builder /root/ros2_ws /root/ros2_ws

# Copy kortex_description and robotiq_description install directories from builder.
# These provide the mesh files (.dae) needed to resolve package://kortex_description/...
# and package://robotiq_description/... URIs from robot_description messages sent by rossim.
COPY --from=slicer-builder /root/ros2_ws/install/kortex_description /root/ros2_ws/install/kortex_description
COPY --from=slicer-builder /root/ros2_ws/install/robotiq_description /root/ros2_ws/install/robotiq_description

# Add the description packages to AMENT_PREFIX_PATH so ROS2 package:// URI
# resolution can find them at runtime when Slicer loads the robot model
ENV AMENT_PREFIX_PATH=/root/ros2_ws/install/kortex_description:/root/ros2_ws/install/robotiq_description

# Also bake the AMENT_PREFIX_PATH into shell startup so GUI-launched Slicer inherits it
RUN echo 'export AMENT_PREFIX_PATH=/root/ros2_ws/install/kortex_description:/root/ros2_ws/install/robotiq_description:${AMENT_PREFIX_PATH}' >> /etc/bash.bashrc \
    && echo 'export AMENT_PREFIX_PATH=/root/ros2_ws/install/kortex_description:/root/ros2_ws/install/robotiq_description:${AMENT_PREFIX_PATH}' >> /etc/profile \
    && echo 'export AMENT_PREFIX_PATH=/root/ros2_ws/install/kortex_description:/root/ros2_ws/install/robotiq_description:${AMENT_PREFIX_PATH}' >> /dockerstartup/kasm_default_profile.sh

# Extract and set up Slicer
RUN cd /root/slicer/packages && \
    tar -xzf Slicer-*.tar.gz && \
    SLICER_DIR=$(find /root/slicer/packages -maxdepth 1 -type d -name "Slicer-*" | head -1) && \
    ln -s ${SLICER_DIR}/Slicer /usr/local/bin/Slicer

COPY --from=slicer-builder /root/slicer/ros2_loadable_modules /root/slicer/ros2_loadable_modules

RUN SLICER_DIR=$(find /root/slicer/packages -maxdepth 1 -type d -name "Slicer-*" | head -1) && \
    mkdir -p "${SLICER_DIR}/lib/Slicer-5.8/qt-loadable-modules" && \
    cp -r /root/slicer/ros2_loadable_modules/. "${SLICER_DIR}/lib/Slicer-5.8/qt-loadable-modules/" && \
    echo "=== ROS2 modules installed ===" && \
    ls "${SLICER_DIR}/lib/Slicer-5.8/qt-loadable-modules/" | grep -i ros

COPY dockerfiles/optimized/slicer/install-extension.py /root/slicer
COPY dockerfiles/optimized/slicer/install-module.py /root/slicer
COPY dockerfiles/optimized/slicer/start-slicer-ros2.bash /root


# Install Slicer modules (excluding SlicerTMS which is installed separately)
RUN cd /root/slicer/packages && \
    SLICER_DIR=$(find /root/slicer/packages -maxdepth 1 -type d -name "Slicer-*" | head -1) && \
    echo "=== Installing extensions to: ${SLICER_DIR} ===" && \
    for module in *SlicerOpenIGTLink*.tar.gz *SlicerIGSIO*.tar.gz *SlicerIGT*.tar.gz *ParallelProcessing*.tar.gz *SlicerDMRI*.tar.gz; do \
        if [ -f "$module" ]; then \
            echo "=== Installing $module ===" && \
            tar -xzf "$module" -C "${SLICER_DIR}" --strip-components=1 && \
            echo "=== Successfully installed $module ===" ; \
        fi \
    done

# Install SlicerROS2 loadable module into Slicer
# Copy pre-built SlicerROS2 module from builder
# COPY --from=slicer-builder /root/slicer/ros2_module_install /root/slicer/ros2_module_install

# # Install into Slicer
# RUN SLICER_DIR=$(find /root/slicer/packages -maxdepth 1 -type d -name "Slicer-*" | head -1) && \
#     cp -r /root/slicer/ros2_module_install/. "${SLICER_DIR}/"

#
# SlicerTMS (Python scripted module) - FIXED VERSION
#
COPY SlicerTMS /root/slicer/modules/SlicerTMS
RUN cd /root/slicer/modules && \
    SLICER_DIR=$(find /root/slicer/packages -maxdepth 1 -type d -name "Slicer-*" | head -1) && \
    echo "=== Installing SlicerTMS directly (Python module) ===" && \
    echo "=== Contents of SlicerTMS directory ===" && \
    ls -la SlicerTMS/ && \
    ls -la SlicerTMS/client/ && \
    ls -la SlicerTMS/data/ && \
    echo "=== Creating module directory ===" && \
    mkdir -p "${SLICER_DIR}"/lib/Slicer-5.8/qt-scripted-modules && \
    echo "=== Copying module files (recursively to preserve subdirectories) ===" && \
    cp -r SlicerTMS/client/SlicerTMS/* "${SLICER_DIR}"/lib/Slicer-5.8/qt-scripted-modules/ && \
    echo "=== Creating data directory at lib/data (two levels up from qt-scripted-modules) ===" && \
    mkdir -p "${SLICER_DIR}"/lib/data && \
    echo "=== Copying data files ===" && \
    cp -r SlicerTMS/data/* "${SLICER_DIR}"/lib/data/ && \
    echo "=== Verifying installation ===" && \
    echo "Module files:" && \
    ls -la "${SLICER_DIR}"/lib/Slicer-5.8/qt-scripted-modules/ && \
    echo "Data files:" && \
    ls -la "${SLICER_DIR}"/lib/data/ && \
    echo "=== SlicerTMS installation complete ==="

RUN cd /root \
    && chmod 755 start-slicer-ros2.bash

WORKDIR /root
# ==============================================================================
# SOLUTION: Multiple approaches to ensure environment variables are available
# ==============================================================================

# Set environment variables in Dockerfile (base level)
ENV TMS_SERVER_HOST=tmsserver
ENV TMS_SERVER_PORT_1=18944
ENV TMS_SERVER_PORT_2=18945

# Approach 1: Add to system-wide profile (loaded by login shells)
RUN echo 'export TMS_SERVER_HOST="${TMS_SERVER_HOST:-tmsserver}"' >> /etc/profile && \
    echo 'export TMS_SERVER_PORT_1="${TMS_SERVER_PORT_1:-18944}"' >> /etc/profile && \
    echo 'export TMS_SERVER_PORT_2="${TMS_SERVER_PORT_2:-18945}"' >> /etc/profile

# Approach 2: Add to bash.bashrc (loaded by non-login interactive shells)
RUN echo 'export TMS_SERVER_HOST="${TMS_SERVER_HOST:-tmsserver}"' >> /etc/bash.bashrc && \
    echo 'export TMS_SERVER_PORT_1="${TMS_SERVER_PORT_1:-18944}"' >> /etc/bash.bashrc && \
    echo 'export TMS_SERVER_PORT_2="${TMS_SERVER_PORT_2:-18945}"' >> /etc/bash.bashrc

# Approach 3: Add to environment file (loaded by pam_env)
RUN echo "TMS_SERVER_HOST=tmsserver" >> /etc/environment && \
    echo "TMS_SERVER_PORT_1=18944" >> /etc/environment && \
    echo "TMS_SERVER_PORT_2=18945" >> /etc/environment

# Approach 4: Add to Kasm startup script so GUI apps inherit env variables
RUN echo 'export TMS_SERVER_HOST="${TMS_SERVER_HOST:-tmsserver}"' >> /dockerstartup/kasm_default_profile.sh && \
    echo 'export TMS_SERVER_PORT_1="${TMS_SERVER_PORT_1:-18944}"' >> /dockerstartup/kasm_default_profile.sh && \
    echo 'export TMS_SERVER_PORT_2="${TMS_SERVER_PORT_2:-18945}"' >> /dockerstartup/kasm_default_profile.sh

# Optional: Add Slicer to PATH
ENV PATH="/root/slicer/packages/Slicer-*/bin:${PATH}"

# Set a password for kasm-user and grant sudo access
RUN echo "kasm-user:yourpassword" | chpasswd && \
    usermod -aG sudo kasm-user && \
    echo "kasm-user ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

RUN chown -R kasm-user:kasm-user /root/slicer/packages && \
    chmod -R 755 /root/slicer/packages && \
    chmod 755 /root && \
    chmod 755 /root/slicer



# Switch back to Kasm's default non-root user
USER 1000